{
  "artifactDownloadUrls": [
    "https://github.com/ffedoroff/code-split/releases/download/v0.1.0-alpha.6"
  ],
  "bin": {
    "code-split": "run-code-split.js"
  },
  "dependencies": {
    "detect-libc": "^2.1.2"
  },
  "description": "Code Split CLI — pluggable multi-language structural analysis platform.",
  "devDependencies": {
    "prettier": "^3.8.3"
  },
  "engines": {
    "node": ">=14.14",
    "npm": ">=6"
  },
  "glibcMinimum": {
    "major": 2,
    "series": 35
  },
  "keywords": [
    "development-tools",
    "command-line-utilities",
    "dependency-graph",
    "coupling",
    "refactoring",
    "code-quality",
    "static-analysis"
  ],
  "license": "Apache-2.0",
  "name": "code-split",
  "preferUnplugged": true,
  "repository": "https://github.com/ffedoroff/code-split",
  "scripts": {
    "fmt": "prettier --write **/*.js",
    "fmt:check": "prettier --check **/*.js",
    "postinstall": "node ./install.js"
  },
  "supportedPlatforms": {
    "aarch64-apple-darwin": {
      "artifactName": "code-split-aarch64-apple-darwin.tar.xz",
      "bins": {
        "code-split": "code-split"
      },
      "zipExt": ".tar.xz"
    },
    "aarch64-pc-windows-msvc": {
      "artifactName": "code-split-x86_64-pc-windows-msvc.zip",
      "bins": {
        "code-split": "code-split.exe"
      },
      "zipExt": ".zip"
    },
    "aarch64-unknown-linux-gnu": {
      "artifactName": "code-split-aarch64-unknown-linux-gnu.tar.xz",
      "bins": {
        "code-split": "code-split"
      },
      "zipExt": ".tar.xz"
    },
    "x86_64-apple-darwin": {
      "artifactName": "code-split-x86_64-apple-darwin.tar.xz",
      "bins": {
        "code-split": "code-split"
      },
      "zipExt": ".tar.xz"
    },
    "x86_64-pc-windows-gnu": {
      "artifactName": "code-split-x86_64-pc-windows-msvc.zip",
      "bins": {
        "code-split": "code-split.exe"
      },
      "zipExt": ".zip"
    },
    "x86_64-pc-windows-msvc": {
      "artifactName": "code-split-x86_64-pc-windows-msvc.zip",
      "bins": {
        "code-split": "code-split.exe"
      },
      "zipExt": ".zip"
    },
    "x86_64-unknown-linux-gnu": {
      "artifactName": "code-split-x86_64-unknown-linux-gnu.tar.xz",
      "bins": {
        "code-split": "code-split"
      },
      "zipExt": ".tar.xz"
    }
  },
  "version": "0.1.0-alpha.6",
  "volta": {
    "node": "18.14.1",
    "npm": "9.5.0"
  }
}